# NOTE: APPSEC_* values are validated at startup (pydantic-settings). A typo
# like APPSEC_AI_SCAN_DEPTH=fast or APPSEC_AI_SCAN_MAX_FILES=abc fails loudly
# with a clear error instead of being silently defaulted.

# AI provider configuration. OpenAI is the default; set AI_PROVIDER=anthropic
# to use Claude models instead. Set the API key that matches your provider.
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
#ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional model overrides. APPSEC_AI_SCAN_MODEL wins for scanner requests;
# AI_MODEL applies to all AI features when no scanner-specific override exists.
#AI_MODEL=gpt-5.6-terra              # e.g. claude-sonnet-5 when AI_PROVIDER=anthropic
#APPSEC_AI_SCAN_MODEL=gpt-5.6-terra


# Scanner Configuration
# (SEMGREP_TIMEOUT / GITLEAKS_TIMEOUT / TRIVY_TIMEOUT used to live here but
# were never wired into the scanner subprocess calls. Removed to stop
# advertising config that does nothing. Scanner timeouts are hardcoded in
# src/scanners/*.py at 300s for semgrep/trivy and 120s for gitleaks.)
APPSEC_SCAN_LEVEL=critical-high     # critical-high (default) or all
                                     # Note: Code quality findings are ALWAYS shown (regardless of this setting)
                                     # This setting only affects SECURITY findings

# Tool Selection (CLI/Web only - MCP and CI/CD always run all tools)
# Comma-separated list of tools to run
# Options: semgrep, trivy, gitleaks, code_quality, sbom, all
# Examples:
#   APPSEC_TOOLS=all                    # Run all tools (default)
#   APPSEC_TOOLS=semgrep,gitleaks       # Only SAST + secrets
#   APPSEC_TOOLS=trivy                  # Only dependency scanning
#   APPSEC_TOOLS=semgrep,code_quality   # SAST + code quality
APPSEC_TOOLS=all

# Code Quality Scanning (ON by default)
# Runs language-specific linters: ESLint (JS/TS), Pylint (Python), Clippy (Rust), etc.
# Note: Semgrep is ONLY for security - code quality is handled by language-specific linters
APPSEC_CODE_QUALITY=true            # Enable code quality linting (recommended)

# Code Quality Severity Filter (Reduce Noise)
# Only show code quality findings at or above this severity level
# Options: critical, high, medium, low, all
# Default: high (filters out low/medium code quality noise)
# Note: Security findings are NOT affected by this filter (controlled by APPSEC_SCAN_LEVEL)
APPSEC_CODE_QUALITY_MIN_SEVERITY=high

# AI-native security scanner (uses OpenAI or Anthropic to find logic vulnerabilities)
# This scanner finds issues that rule-based tools (semgrep/trivy/gitleaks) cannot:
# auth bypasses, race conditions, IDOR, business logic flaws, crypto misuse
APPSEC_AI_SCAN=false               # Set to 'true' to enable AI scanning (incurs API cost)
APPSEC_AI_SCAN_DEPTH=standard       # quick, standard, or deep
APPSEC_AI_SCAN_MAX_FILES=50         # Max files to analyze per scan (controls cost)
APPSEC_AI_SCAN_TIER=3               # Client privacy: 1=no AI, 2=snippets only, 3=full source
#APPSEC_AI_SCAN_MODEL=              # Override model ID (uses depth default if not set)

# AI-Powered Cross-File Enhancement (Phase 2 - v2.1.0)
# When APPSEC_AI_SCAN=true and tier=3, an LLM additionally validates attack
# chains, correlates findings for compound risks, and checks sanitization.
# These caps are cost guardrails for big repos.
APPSEC_AI_CROSS_FILE_MAX_CHAINS=30        # Max attack chains the LLM validates
APPSEC_AI_CROSS_FILE_MAX_FINDINGS=30      # Max findings the LLM correlates
APPSEC_AI_CROSS_FILE_MAX_SANITIZATION=20  # Max findings checked for sanitization
APPSEC_AI_CROSS_FILE_MAX_SECONDS=300      # Wall-clock budget for the entire phase

# --- Default model IDs used by the AI scanner (by depth) ---
#   openai:     quick: gpt-5.6-luna     standard: gpt-5.6-terra   deep: gpt-5.6-sol
#   anthropic:  quick: claude-haiku-4-5 standard: claude-sonnet-5 deep: claude-opus-4-8
# Select depth via APPSEC_AI_SCAN_DEPTH; only override the exact model via APPSEC_AI_SCAN_MODEL.

# Logging & Debug
APPSEC_LOG_LEVEL=INFO          # Set log level: DEBUG, INFO, WARNING, ERROR
APPSEC_DEBUG=false             # Enable debug mode for troubleshooting
LOG_LEVEL=INFO                 # Legacy logging configuration

# Auto-Fix (CI/CD and web; the CLI asks interactively)
#APPSEC_AUTO_FIX=false                  # 'true' enables auto-fix without prompting (CI/web)
#APPSEC_AUTO_FIX_MODE=                  # 1=SAST+secrets, 2=dependencies, 3=both, 4=skip
APPSEC_AUTO_FIX_DELAY=5                 # Seconds to wait before applying auto-fix (default: 5)

# GitHub token used to push auto-fix branches and open pull requests.
# Needs 'repo' scope. Only required when auto-remediation creates PRs.
#GITHUB_TOKEN=your-github-token-here

# PR-Diff Scoping (fast PR feedback; run full scans on main)
APPSEC_DIFF_ONLY=false                   # 'true' keeps only findings in files changed vs base ref
APPSEC_DIFF_BASE=origin/main             # Base ref for the diff (falls back to origin/master)

# Exploit Intelligence (EPSS scores + CISA KEV catalog for Trivy CVEs)
APPSEC_VULN_INTEL=true                   # 'false' disables the network lookups (scan still works offline)

# Output retention: per-repo scan outputs (which can include raw detected
# secrets) are purged after this many days without a new scan. 0 disables.
APPSEC_OUTPUT_RETENTION_DAYS=30

# Baseline suppression: put a .appsec-galaxy-ignore file in the scanned repo's root
# (one tool:rule:path-glob pattern per line) to silence accepted findings.

# Dependency Analysis
APPSEC_DEPENDENCY_ANALYSIS=true          # Enable dependency health analysis
APPSEC_DEP_HEALTH_CHECK=true             # Check package health (maintenance, popularity)
# Removed: APPSEC_DEP_INLINE_THRESHOLD (0.3), APPSEC_PACKAGE_STALE_MONTHS (18),
# APPSEC_PACKAGE_ABANDONED_MONTHS (36), APPSEC_REGISTRY_CACHE_TTL (3600).
# These were internal heuristic thresholds nobody tuned. Hardcoded in src/config.py.

# Web UI directory browsing (Browse Common Locations button).
# OFF by default on purpose: a web server should not expose filesystem
# browsing unless you opt in. Safe to enable for local development.
APPSEC_ENABLE_DIRECTORY_BROWSING=true

# Web server (start_web.sh / python -m appsec_galaxy.web_app)
#HOST=0.0.0.0                            # Bind address (default 0.0.0.0 = all interfaces/LAN)
#PORT=8000                               # Port (default 8000)
#APPSEC_WEB_API_KEY=                     # If set, scan/report endpoints require X-API-Key header
#APPSEC_WEB_CORS_ORIGINS=                # Comma-separated allowed origins (default: none)

# Repository Discovery
REPO_SEARCH_PATHS=                       # Comma-separated custom search paths for CLI repo discovery

# Business Metrics (for cost calculations)
SECURITY_ENGINEER_HOURLY_RATE=150 
