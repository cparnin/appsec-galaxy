# AI provider: openai (default) or anthropic. Set the matching API key.
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
#ANTHROPIC_API_KEY=your-anthropic-api-key-here
APPSEC_SCAN_LEVEL=all
APPSEC_AI_SCAN=true
APPSEC_AI_SCAN_DEPTH=standard
APPSEC_AI_SCAN_TIER=3
APPSEC_AI_SCAN_MAX_FILES=75
APPSEC_AI_SCAN_MIN_CONFIDENCE=0.7
