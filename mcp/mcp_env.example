# AI provider: openai (default) or anthropic. Set the matching API key.
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
#ANTHROPIC_API_KEY=your-anthropic-api-key-here
APPSEC_SCAN_LEVEL=all
APPSEC_AI_SCAN=true
APPSEC_AI_SCAN_DEPTH=standard
APPSEC_AI_SCAN_TIER=3
APPSEC_AI_SCAN_MAX_FILES=75
#APPSEC_AI_SCAN_MAX_COST=1.00      # Hard USD ceiling per AI scan (unset = no cap)
#APPSEC_SEMGREP_CONFIG=p/default   # Pinned Semgrep rulesets (comma-separated; 'auto' = dynamic)

# GitHub token for auto-remediation PRs (repo scope)
#GITHUB_TOKEN=your-github-token-here

# MCP tool timeouts in seconds (defaults: scan 300, remediate 600)
#MCP_SCAN_TIMEOUT=300
#MCP_REMEDIATE_TIMEOUT=600

# Path to the AppSec Galaxy checkout the server should use. Only needed when
# the server is launched from outside the repo (otherwise auto-detected).
#APPSEC_GALAXY_PATH=/path/to/appsec-galaxy

# Allowlist of directories a tool may scan (colon-separated). When set, it
# replaces the broad defaults (~/repos, ~/projects, ~, .) so a client cannot
# point the scanner at arbitrary local paths. Recommended.
#APPSEC_MCP_ALLOWED_ROOTS=/path/to/repos:/path/to/more
